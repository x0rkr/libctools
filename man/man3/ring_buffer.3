.TE
.SH EXAMPLES
Below is a simple usage snippet within an interrupt-driven UART driver:
.PP
.EX
#include <libctools.h>

ring_buffer_t rx_buffer;

void uart_init(void) {
    ring_buffer_init(&rx_buffer);
}

// Interrupt Service Routine (Producer)
void UART_RX_IRQHandler(void) {
    uint8_t byte = UART_READ_REG();
    ring_buffer_push(&rx_buffer, byte);
}

// Main processing loop (Consumer)
void process_incoming_data(void) {
    uint8_t next_byte;
    while (ring_buffer_pop(&rx_buffer, &next_byte)) {
        // Process byte
    }
}
.EE

